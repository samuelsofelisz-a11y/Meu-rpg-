<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<title>HUD Unificado — Arma, Vida, Perícias, Estimulantes e Debuffs</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#000;color:#fff;font-family:'Segoe UI',sans-serif;display:flex;height:100vh;width:100vw;overflow:hidden}

/* ===== COLUNAS ===== */
.coluna{flex:1;border-left:2px solid #00fff2;display:flex;flex-direction:column;align-items:center;position:relative}
.coluna:first-child{border-left:none}
.titulo{font-size:2em;font-weight:bold;color:#00fff2;text-shadow:0 0 8px #00fff2;position:absolute;top:20px;text-align:center;letter-spacing:2px;z-index:10}

/* ===== GRID / ARMAS (layout preservado) ===== */
.grid-fuzil{position:absolute;top:193px;left:43%;transform:translateX(-50%);width:740px;height:398px;background:rgba(0,255,255,.05);border:2px solid #00fff2;border-radius:12px;display:flex;align-items:center;justify-content:center;z-index:5;box-shadow:0 0 20px #00fff266;transition:all .3s ease}
.grid-azul{border-color:#00fff2;box-shadow:0 0 20px #00fff266,0 0 30px #00fff244 inset}
.grid-laranja{border-color:#ff7b00;box-shadow:0 0 25px #ff7b0077,0 0 40px #ff7b0044 inset}
.fuzil-inner img{position:absolute;transition:transform .25s ease,opacity .25s ease,filter .3s ease;pointer-events:auto;cursor:pointer}
#fuzilImg{top:54%;left:50%;width:88%;transform:translate(-50%,-50%) scale(1);filter:drop-shadow(0 0 12px #00fff2cc)}
#fuzilImg:hover{transform:translate(-50%,-50%) scale(1.1)}
#pistolaImg{top:53%;left:55%;width:55%;transform:translate(-50%,-50%) scale(1);opacity:0;pointer-events:none;filter:drop-shadow(0 0 12px #00fff2cc)}
#pistolaImg.visivel{opacity:1;pointer-events:auto}
#pistolaImg:hover{transform:translate(-50%,-50%) scale(1.1)}
.botao-troca{position:absolute;top:-42px;right:-62px;width:60px;height:60px;background:none;border:none;cursor:pointer;z-index:10;display:flex;align-items:center;justify-content:center}
.botao-troca img{width:100%;height:100%;filter:drop-shadow(0 0 10px #00fff2);transition:transform .4s ease}
.botao-troca .animar{transform:scale(1.3) rotate(360deg)}
.municao-display{position:absolute;top:93px;left:57%;transform:translateX(-50%);z-index:15;text-align:center}
.contador{font-size:2.4em;font-weight:bold;letter-spacing:2px;text-shadow:0 0 10px #00fff2;color:#00fff2;white-space:nowrap}
.contador.laranja{color:#ff7b00;text-shadow:0 0 10px #ff7b00}
.contador.inativo{display:none}
.icone-tipo{position:absolute;top:90px;left:67%;width:100px;height:100px;cursor:pointer;transition:transform .2s ease,filter .3s ease;z-index:15}
.icone-tipo:hover{transform:scale(1.1)}
.icone-azul{filter:drop-shadow(0 0 18px #00fff2cc) brightness(1.3)}
.icone-laranja{filter:drop-shadow(0 0 18px #ff7b00cc) brightness(1.5)}
#nomeMunicao{position:absolute;top:68px;left:67%;transform:translateX(-50%);font-size:1.05em;font-weight:bold;letter-spacing:.5px;color:#00fff2;text-shadow:0 0 8px #00fff2;z-index:16;user-select:none;pointer-events:none}
#nomeMunicao.laranja{color:#ff7b00;text-shadow:0 0 8px #ff7b00}
.botao-recarregar{position:absolute;top:148px;left:57%;transform:translateX(-50%);background:transparent;color:#00fff2;border:3px solid #00fff2;padding:8px 23px;border-radius:8px;font-weight:bold;cursor:pointer;transition:.2s;text-transform:uppercase;z-index:15}
.botao-recarregar:hover{background:#00fff2;color:#000;box-shadow:0 0 10px #00fff2}

/* Granadas */
#nomeGranada{position:absolute;top:59px;left:36%;transform:translateX(-50%);color:#00fff2;font-size:1.2em;font-weight:bold;text-shadow:0 0 10px #00fff2;z-index:16}
#iconeGranada{position:absolute;top:86px;left:30%;width:107px;height:107px;cursor:pointer;filter:drop-shadow(0 0 10px #00fff2);transition:transform .2s ease;z-index:16}
#iconeGranada:hover{transform:scale(1.1)}
#contadorGranada{position:absolute;top:95px;left:23%;color:#00fff2;font-size:2.7em;font-weight:bold;text-shadow:0 0 10px #00fff2;z-index:16}
#botaoUsarGranada{position:absolute;top:150px;left:24%;transform:translateX(-50%);background:transparent;color:#00fff2;border:3px solid #00fff2;padding:8px 20px;border-radius:8px;font-weight:bold;text-transform:uppercase;cursor:pointer;z-index:16;transition:.2s}
#botaoUsarGranada:hover{background:#00fff2;color:#000;box-shadow:0 0 10px #00fff2}

/* Caixas de disparo */
.caixas-inferiores{position:absolute;top:calc(200px + 398px + 8px);left:43%;transform:translateX(-50%);display:flex;gap:20px;z-index:6}
.caixa{width:90px;height:90px;border:2px solid #00fff2;border-radius:10px;background:rgba(0,255,255,.05);box-shadow:0 0 8px #00fff266;display:flex;align-items:center;justify-content:center;color:#00fff2;font-size:2em;font-weight:bold;cursor:pointer;transition:.2s;user-select:none}
.caixa:hover{transform:scale(1.08);box-shadow:0 0 15px #00fff2}
.caixa.ativo{box-shadow:0 0 18px #00fff2,0 0 35px #00fff233 inset;color:#00fff2}
.caixa.bloqueado{border-color:rgba(255,255,255,.08);color:rgba(255,255,255,.12);box-shadow:none;cursor:not-allowed;background:rgba(255,255,255,.01)}
.caixa .x{font-size:2em;color:rgba(255,255,255,.18)}

/* Divisão / Perícias título */
.linha-divisao{position:absolute;top:calc(200px + 398px + 8px + 90px + 12px);left:43%;transform:translateX(-50%);width:1000px;height:3px;background:linear-gradient(90deg,transparent,#00fff2,transparent);box-shadow:0 0 15px #00fff266}
.titulo-pericia{position:absolute;top:calc(200px + 398px + 8px + 90px + 12px + 20px);left:43%;transform:translateX(-50%);font-size:1.8em;font-weight:bold;color:#00fff2;text-shadow:0 0 8px #00fff2;letter-spacing:2px;z-index:8}

/* ===== PERÍCIAS (lista detalhada) ===== */
.pericia-container{position:absolute;top:calc(200px + 398px + 8px + 90px + 12px + 60px);left:43%;transform:translateX(-50%);display:grid;grid-template-columns:repeat(3,220px);grid-auto-rows:auto;gap:25px 60px;z-index:8}
.coluna-pericia{border:2px solid #00fff2;border-radius:12px;background:rgba(0,255,255,.05);box-shadow:0 0 10px #00fff266;display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-start;padding:10px 15px;color:#00fff2;font-weight:bold;transition:.2s;width:220px;min-height:180px;cursor:default}
.coluna-pericia:hover{transform:scale(1.05);box-shadow:0 0 15px #00fff2}
.coluna-pericia .atributo{font-size:1.2em;margin-bottom:8px;text-shadow:0 0 6px #00fff2;text-transform:uppercase;text-align:left;width:100%;padding-left:5px}
.coluna-pericia ul{list-style:none;padding-left:10px;margin:0;width:100%}
.coluna-pericia li{font-size:.95em;font-weight:normal;margin:3px 0;color:#b8ffff;text-align:left}
.mod{color:#00ff66;font-weight:bold;text-shadow:0 0 6px #00ff66;margin-left:6px}

/* Box de atributos clicável */
#boxAtributos{cursor:pointer}
#boxAtributos:hover{transform:scale(1.05);box-shadow:0 0 18px #00fff2}

/* ===================== COLUNA: VIDA ===================== */
.vida-frame{position:absolute;top:10px;left:calc(49% - 500px);width:800px;height:420px;background-image:url('https://i.imgur.com/y2moow7.png');background-size:contain;background-repeat:no-repeat;background-position:center;pointer-events:none;z-index:5;transition:filter .3s ease}
.placas-contador{position:absolute;top:70px;left:47%;transform:translateX(-50%);display:flex;gap:5px;z-index:1000;pointer-events:none}
.placas-contador img{width:45px;height:45px;opacity:0;transform:scale(.8);transition:all .3s ease;filter:drop-shadow(0 0 8px #000)}
.placas-contador img.ativo{opacity:1;transform:scale(1);animation:brilhoEscudo 1s infinite alternate}
@keyframes brilhoEscudo{from{filter:drop-shadow(0 0 10px #ff8c00) brightness(1.1)}to{filter:drop-shadow(0 0 25px #ffaa33) brightness(1.6)}}
.efeito-vermelho{animation:pulsarVermelho .6s infinite alternate}
.efeito-verde{animation:pulsarVerde .6s infinite alternate}
@keyframes pulsarVermelho{from{filter:drop-shadow(0 0 10px #ff0000) brightness(1)}to{filter:drop-shadow(0 0 25px #ff4d4d) brightness(1.4)}}
@keyframes pulsarVerde{from{filter:drop-shadow(0 0 10px #00ff66) brightness(1)}to{filter:drop-shadow(0 0 25px #00ffcc) brightness(1.5)}}
.status-icons{position:absolute;top:310px;left:38%;transform:translateX(-50%);display:flex;gap:7px;z-index:1000;pointer-events:none}
.status-icons img{width:85px;height:85px;opacity:0;transform:scale(.7);transition:all .4s ease;filter:drop-shadow(0 0 8px #000)}
.status-icons img.ativo{opacity:1;transform:scale(1)}
#iconSangramento.ativo{animation:brilhoVermelho .8s infinite alternate}
#iconVeneno.ativo{animation:brilhoVerde .8s infinite alternate}
#iconLesao.ativo{animation:lesaoPulse .9s infinite alternate}
@keyframes lesaoPulse{from{filter:drop-shadow(0 0 10px #ffd54d) brightness(1.0)}to{filter:drop-shadow(0 0 26px #ffea82) brightness(1.3)}}

/* Barra de Vida */
.vida-barra{position:absolute;top:188px;left:calc(49% - 154px);width:379px;height:60px;border-radius:4px;overflow:hidden;z-index:6;background:#111}
.vida-preenchimento{height:100%;background:linear-gradient(90deg,#00ffff,#00b3ff);border-radius:4px;transition:width .3s ease;position:absolute;left:0;top:0;z-index:7}
.vida-extra{height:100%;background:linear-gradient(90deg,#ffb347,#ff7b00);border-radius:0 4px 4px 0;transition:all .3s ease;position:absolute;top:0;z-index:8}
.vida-contador{position:absolute;top:260px;left:calc(50% - 50px);color:#00fff2;font-size:1.5em;text-shadow:0 0 8px #00fff2;font-weight:bold;z-index:10}

/* Painel Dano */
.painel-dano{position:absolute;top:195px;left:calc(47% + 260px);display:flex;align-items:center;gap:10px;z-index:20}
.painel-dano input{width:220px;height:50px;border:2px solid #00fff2;border-radius:6px;background:#111;color:#00fff2;text-align:center;font-size:1em;outline:none}
.painel-dano button{background:#00fff2;border:none;color:#000;font-weight:bold;padding:6px 14px;border-radius:6px;cursor:pointer;transition:.2s}
.painel-dano button:hover{background:#00ff99;transform:scale(1.1)}

/* Atributos rápidos */
.armadura,.sanidade,.resistencia{position:absolute;display:flex;align-items:center;gap:6px;z-index:25}
.armadura{top:115px;left:calc(50% + 224px)}
.sanidade{top:115px;left:calc(50% + 320px)}
.resistencia{top:45px;left:calc(50% + 225px)}
.armadura img,.sanidade img,.resistencia img{width:55px;height:55px}
.armadura span,.sanidade span,.resistencia span{color:#00fff2;font-weight:bold;font-size:1.2em}
.botoes-sani{display:flex;flex-direction:column;align-items:center;gap:2px}
.sanidade button{background:transparent;border:none;color:#00fff2;font-size:1.2em;cursor:pointer;transition:transform .1s ease}
.sanidade button:hover{transform:scale(1.3);color:#00ff99}

/* Grade de Itens (cura/spray/placa + ESTIMULANTES no 4º grid) */
.itens{position:absolute;top:480px;left:50%;transform:translateX(-50%);display:grid;grid-template-columns:repeat(2,300px);grid-template-rows:repeat(2,300px);gap:170px;z-index:30}
.item{width:300px;height:300px;background:rgba(0,255,255,.05);border:2px solid #00fff2;border-radius:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;position:relative}
.item-inner{width:100%;height:100%;display:flex;align-items:center;justify-content:center;overflow:hidden;border-radius:10px;position:relative}
.item img{width:90%;height:90%;object-fit:contain;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(1);transition:transform .25s ease,opacity .25s ease}
.item-inner:hover img{transform:translate(-50%,-50%) scale(1.15);z-index:10}

/* 4º grid: seletor vertical para Estimulantes */
#item-estims .seletores-verticais{position:absolute;left:-78px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:10px;z-index:100}
#item-estims .seletor{width:70px;height:70px;background:#111;border:2px solid #00fff2;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#00fff2;font-weight:bold;font-size:1.5em;cursor:pointer;transition:.2s}
#item-estims .seletor:hover{background:#00fff2;color:#000}
#item-estims .seletor.ativo{background:#00fff2;color:#000;box-shadow:0 0 15px #00fff2}
#item-estims img{opacity:0;pointer-events:none}
#item-estims img.ativo{opacity:1;pointer-events:auto;filter:drop-shadow(0 0 18px #00fff2) brightness(1.3)}

/* Popups (estimulantes + cura/spray/placa + atributos) */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);justify-content:center;align-items:center;z-index:999}
.overlay.ativo{display:flex}
.popup{background:#111;border:2px solid #00fff2;border-radius:10px;padding:22px 24px;width:440px;max-width:92vw;color:#00fff2;text-align:center;box-shadow:0 0 18px #00fff266}
.popup h2{margin:0 0 8px;text-shadow:0 0 10px currentColor}
.popup p{margin:6px 0;color:#b8ffff}
.popup .botoes{margin-top:14px;display:flex;gap:12px;justify-content:center}
.popup button{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-weight:bold;transition:.2s}
.popup .usar{background:#00fff2;color:#000}
.popup .fechar{background:#111;color:#00fff2;border:2px solid #00fff2}
.popup .usar:hover{background:#00ff99}
.popup .fechar:hover{background:#00fff2;color:#000}
.cooldown{font-size:.9em;color:#8ff;opacity:.85;margin-top:8px}

/* Form de atributos no popup */
#formAtributos{display:flex;flex-direction:column;gap:8px;text-align:left;margin-top:10px}
#formAtributos label{display:flex;justify-content:space-between;align-items:center;font-size:.95em}
#formAtributos input{width:70px;background:#000;border:1px solid #00fff2;border-radius:4px;color:#00fff2;text-align:center;padding:4px}
</style>
</head>
<body>

<!-- ===================== COLUNA ARMA ===================== -->
<div class="coluna" id="arma">
  <div class="titulo">ARMA</div>

  <div class="municao-display">
    <div id="contadorFuzilNormal" class="contador">30 / 90</div>
    <div id="contadorFuzilAB" class="contador laranja inativo">25 / 75</div>
    <div id="contadorPistola" class="contador inativo">12 / 36</div>
  </div>

  <div id="nomeMunicao">MUNIÇÃO BASE</div>
  <img id="iconeTipo" class="icone-tipo icone-azul" src="https://i.imgur.com/yBeSBbD.png" alt="Tipo de munição" onclick="trocarMunicao()">
  <button class="botao-recarregar" onclick="recarregar()">RECARREGAR</button>

  <div id="nomeGranada">GRANADA</div>
  <img id="iconeGranada" src="https://i.imgur.com/YNr8ppm.png" alt="Granada" onclick="trocarGranada()">
  <div id="contadorGranada">3</div>
  <button id="botaoUsarGranada" onclick="usarGranada()">USAR</button>

  <div class="grid-fuzil grid-azul" id="gridFuzil">
    <div class="fuzil-inner">
      <img id="fuzilImg" src="https://i.imgur.com/nRsouNy.png" alt="Fuzil">
      <img id="pistolaImg" src="https://i.imgur.com/KY3TIlI.png" alt="Pistola">
    </div>
    <button class="botao-troca" onclick="trocarArma()">
      <img id="imgTroca" src="https://i.imgur.com/LehbrQR.png" alt="Trocar Arma">
    </button>
  </div>

  <div class="caixas-inferiores" id="botoesTiro">
    <div class="caixa" data-index="1">1</div>
    <div class="caixa" data-index="2">2</div>
    <div class="caixa" data-index="3">3</div>
    <div class="caixa" data-index="4">4</div>
    <div class="caixa" data-index="5">5</div>
  </div>

  <div class="linha-divisao"></div>
  <div class="titulo-pericia">PERÍCIAS</div>

  <!-- ===================== PERÍCIAS (5 ATRIBUTOS + ATRIBUTOS BOX) ===================== -->
  <div class="pericia-container" id="pericias">
    <div class="coluna-pericia" data-atrib="FORÇA">
      <div class="atributo">FORÇA</div>
      <ul>
        <li>Atletismo <span class="mod">+1</span></li>
        <li>Briga <span class="mod">+1</span></li>
        <li>Armas Brancas <span class="mod">+1</span></li>
        <li>Armas Pesadas <span class="mod">+1</span></li>
        <li>Contra-ataque <span class="mod">+1</span></li>
      </ul>
    </div>

    <div class="coluna-pericia" data-atrib="CONSTITUIÇÃO">
      <div class="atributo">CONSTITUIÇÃO</div>
      <ul>
        <li>Resistência Física <span class="mod">+1</span></li>
        <li>Tolerância à Dor <span class="mod">+1</span></li>
        <li>Resistência a Toxinas <span class="mod">+1</span></li>
        <li>Fôlego <span class="mod">+1</span></li>
        <li>Resistência Psicológica <span class="mod">+1</span></li>
      </ul>
    </div>

    <div class="coluna-pericia" data-atrib="DESTREZA">
      <div class="atributo">DESTREZA</div>
      <ul>
        <li>Acrobacia <span class="mod">+1</span></li>
        <li>Pontaria <span class="mod">+1</span></li>
        <li>Furtividade <span class="mod">+1</span></li>
        <li>Ladeagem <span class="mod">+1</span></li>
        <li>Reflexo <span class="mod">+1</span></li>
      </ul>
    </div>

    <div class="coluna-pericia" data-atrib="INTELIGÊNCIA">
      <div class="atributo">INTELIGÊNCIA</div>
      <ul>
        <li>Investigação <span class="mod">+1</span></li>
        <li>Hacker <span class="mod">+1</span></li>
        <li>Medicina <span class="mod">+1</span></li>
        <li>Estratégia <span class="mod">+1</span></li>
        <li>Engenharia <span class="mod">+1</span></li>
      </ul>
    </div>

    <div class="coluna-pericia" data-atrib="PSICOLÓGICO">
      <div class="atributo">PSICOLÓGICO</div>
      <ul>
        <li>Percepção Psicológica <span class="mod">+1</span></li>
        <li>Percepção <span class="mod">+1</span></li>
        <li>Blefe <span class="mod">+1</span></li>
        <li>Vontade <span class="mod">+1</span></li>
      </ul>
    </div>

    <!-- NOVO: GRID DE ATRIBUTOS -->
    <div class="coluna-pericia" id="boxAtributos">
      <div class="atributo">ATRIBUTOS</div>
      <ul id="listaAtributos">
        <!-- preenchido via JS -->
      </ul>
    </div>
  </div>
</div>

<!-- ===================== COLUNA VIDA ===================== -->
<div class="coluna" id="vida">
  <div class="titulo">VIDA</div>

  <div class="vida-frame" id="vidaFrame">
    <div class="placas-contador">
      <img id="placaIcon1" src="https://i.imgur.com/n8cgQJU.png" alt="Placa 1">
      <img id="placaIcon2" src="https://i.imgur.com/n8cgQJU.png" alt="Placa 2">
    </div>
  </div>

  <div class="vida-barra">
    <div class="vida-preenchimento" id="vidaBarra"></div>
    <div class="vida-extra" id="vidaExtra"></div>
  </div>
  <div class="vida-contador" id="vidaContador">HP: 250 / 250</div>

  <div class="status-icons">
    <img id="iconSangramento" src="https://i.imgur.com/CPcHMYH.png" alt="Sangramento">
    <img id="iconVeneno"     src="https://i.imgur.com/DiIt9ie.png" alt="Veneno">
    <img id="iconLesao"      src="https://i.imgur.com/MvAV7lb.png" alt="Lesão">
  </div>

  <div class="resistencia"><img src="https://i.imgur.com/Q1uRV7U.png" alt="Resistência"><span id="valorResistencia">5%</span></div>
  <div class="armadura"><img src="https://i.imgur.com/swwVkhi.png" alt="Armadura"><span id="valorArmadura">50</span></div>
  <div class="sanidade">
    <img src="https://i.imgur.com/bkVX5N8.png" alt="Sanidade">
    <span id="valorSanidade">30</span>
    <div class="botoes-sani">
      <button onclick="alterarSanidade(1)">▲</button>
      <button onclick="alterarSanidade(-1)">▼</button>
    </div>
  </div>

  <!-- Grade de itens: Cura / Spray / Placa / ESTIMULANTES -->
  <div class="itens" id="gradeItens">
    <div class="item" id="grid-cura"><div class="item-inner"><img src="https://i.imgur.com/r5cyOuh.png" alt="Cura Avançada"></div></div>
    <div class="item" id="grid-spray"><div class="item-inner"><img src="https://i.imgur.com/JDtsZKU.png" alt="Quick Spray"></div></div>
    <div class="item" id="grid-placa"><div class="item-inner"><img src="https://i.imgur.com/udi7MQc.png" alt="Placa Balística"></div></div>

    <!-- 4º GRID: Estimulantes com seletor vertical -->
    <div class="item" id="item-estims" title="Estimulantes">
      <div class="seletores-verticais">
        <div class="seletor ativo" data-img="1">1</div>
        <div class="seletor" data-img="2">2</div>
        <div class="seletor" data-img="3">3</div>
      </div>
      <div class="item-inner" id="stimInner">
        <img id="stim1" src="https://i.imgur.com/4AZzyLr.png" alt="AdrenaBoost">
        <img id="stim2" src="https://i.imgur.com/jwNtLPf.png" alt="Iron Pulse">
        <img id="stim3" src="https://i.imgur.com/RL7ZzHq.png" alt="MidSpark">
      </div>
    </div>
  </div>

  <!-- Painel de dano -->
  <div class="painel-dano">
    <input type="text" id="danoInput" placeholder="Dano ou S/V/L + número (ex: S80, V40, L10, 55)">

syncGranadaUI();
atualizarContadores();
atualizarCaixas();
atualizarRotuloMunicao();
atualizarHUD();
atualizarAtributosBox();
aplicarBonusDaArma(); // arma inicial: fuzil
renderSkills();
</script>

<script>
/* ===================== UTIL POPUPS ===================== */
function abrir(id){document.getElementById(id).classList.add('ativo')}
function fechar(id){document.getElementById(id).classList.remove('ativo')}

/* ===================== ARMA / MUNIÇÃO ===================== */
let armaAtual="fuzil"; // "fuzil" | "pistola"
let tipoMunicao=1;     // 1 base, 2 antiblindagem (só fuzil)
const fuzilNormal={atual:30,reserva:90,max:30};
const fuzilAB={atual:25,reserva:75,max:25};
const pistola={atual:12,reserva:36,max:12};

const contFuzilN=document.getElementById("contadorFuzilNormal");
const contFuzilAB=document.getElementById("contadorFuzilAB");
const contPistola=document.getElementById("contadorPistola");
const iconeTipo=document.getElementById("iconeTipo");
const gridFuzil=document.getElementById("gridFuzil");
const fuzilImg=document.getElementById("fuzilImg");
const pistolaImg=document.getElementById("pistolaImg");
const botaoTrocaImg=document.getElementById("imgTroca");
const nomeMunicao=document.getElementById("nomeMunicao");

function atualizarContadores(){
  contFuzilN.textContent=`${fuzilNormal.atual} / ${fuzilNormal.reserva}`;
  contFuzilAB.textContent=`${fuzilAB.atual} / ${fuzilAB.reserva}`;
  contPistola.textContent=`${pistola.atual} / ${pistola.reserva}`;
}
function atualizarRotuloMunicao(){
  if(armaAtual==="pistola"||tipoMunicao===1){
    nomeMunicao.textContent="MUNIÇÃO BASE";
    nomeMunicao.classList.remove("laranja");
  }else{
    nomeMunicao.textContent="ANTIBLINDAGEM";
    nomeMunicao.classList.add("laranja");
  }
}
function trocarMunicao(){
  if(armaAtual==="pistola")return;
  tipoMunicao=(tipoMunicao===1?2:1);
  contFuzilN.classList.toggle("inativo",tipoMunicao!==1);
  contFuzilAB.classList.toggle("inativo",tipoMunicao!==2);
  if(tipoMunicao===1){
    iconeTipo.src="https://i.imgur.com/yBeSBbD.png";
    iconeTipo.classList.remove("icone-laranja");iconeTipo.classList.add("icone-azul");
    gridFuzil.classList.remove("grid-laranja");gridFuzil.classList.add("grid-azul");
  }else{
    iconeTipo.src="https://i.imgur.com/CUuWQ12.png";
    iconeTipo.classList.remove("icone-azul");iconeTipo.classList.add("icone-laranja");
    gridFuzil.classList.remove("grid-azul");gridFuzil.classList.add("grid-laranja");
  }
  atualizarRotuloMunicao();
}
function trocarArma(){
  botaoTrocaImg.classList.add('animar');
  setTimeout(()=>botaoTrocaImg.classList.remove('animar'),420);

  if(armaAtual==="fuzil"){
    armaAtual="pistola";
    fuzilImg.style.opacity="0";
    pistolaImg.classList.add("visivel");
    tipoMunicao=1;
    iconeTipo.src="https://i.imgur.com/yBeSBbD.png";
    iconeTipo.classList.remove("icone-laranja");iconeTipo.classList.add("icone-azul");
    contFuzilN.classList.add("inativo");
    contFuzilAB.classList.add("inativo");
    contPistola.classList.remove("inativo");
    gridFuzil.classList.remove("grid-laranja");gridFuzil.classList.add("grid-azul");
  }else{
    armaAtual="fuzil";
    fuzilImg.style.opacity="1";
    pistolaImg.classList.remove("visivel");
    contPistola.classList.add("inativo");
    contFuzilN.classList.remove("inativo");
  }
  atualizarContadores();
  atualizarCaixas();
  atualizarRotuloMunicao();
  aplicarBonusDaArma(); // atualiza perícias com nova arma
}
function atirar(qtd){
  if(armaAtual==="pistola"){
    pistola.atual=Math.max(0,pistola.atual-1);
  }else{
    if(tipoMunicao===1)fuzilNormal.atual=Math.max(0,fuzilNormal.atual-qtd);
    else fuzilAB.atual=Math.max(0,fuzilAB.atual-qtd);
  }
  atualizarContadores();
}
function recarregar(){
  let arma=(armaAtual==="pistola")?pistola:(tipoMunicao===1?fuzilNormal:fuzilAB);
  const nec=arma.max-arma.atual, transf=Math.min(nec,arma.reserva);
  arma.atual+=transf;
  arma.reserva-=transf;
  atualizarContadores();
}

/* Caixas tiro */
const caixas=Array.from(document.querySelectorAll('.caixa'));
function atualizarCaixas(){
  if(armaAtual==="fuzil"){
    caixas.forEach((el,i)=>{
      el.classList.remove('bloqueado');
      el.classList.add('ativo');
      el.textContent=(i+1);
      el.dataset.enabled="1";
    });
  }else{
    caixas.forEach((el,i)=>{
      if(i===0){
        el.classList.remove('bloqueado');
        el.classList.add('ativo');
        el.textContent='1';
        el.dataset.enabled="1";
      }else{
        el.classList.remove('ativo');
        el.classList.add('bloqueado');
        el.innerHTML='<span class="x">X</span>';
        el.dataset.enabled="0";
      }
    });
  }
}
caixas.forEach(el=>el.addEventListener('click',()=>{
  const idx=Number(el.dataset.index);
  if(el.dataset.enabled!=="1")return;
  if(armaAtual==="pistola")atirar(1);
  else atirar(idx);
}));

/* ===================== GRANADAS ===================== */
const tiposGranada=[
  {nome:"GRANADA",img:"https://i.imgur.com/YNr8ppm.png"},
  {nome:"FLASHBANG",img:"https://i.imgur.com/7uXVJTP.png"},
  {nome:"SMOKE",img:"https://i.imgur.com/6xn34P5.png"}
];
const escalaGranada=[1,1,1];
let idxGranada=0;
const estoqueGranadas=[3,3,3];
const nomeGranada=document.getElementById("nomeGranada");
const iconeGranada=document.getElementById("iconeGranada");
const contadorGranada=document.getElementById("contadorGranada");
function syncGranadaUI(){
  nomeGranada.textContent=tiposGranada[idxGranada].nome;
  iconeGranada.src=tiposGranada[idxGranada].img;
  iconeGranada.style.transform=`scale(${escalaGranada[idxGranada]})`;
  contadorGranada.textContent=String(estoqueGranadas[idxGranada]);
}
function trocarGranada(){
  idxGranada=(idxGranada+1)%tiposGranada.length;
  syncGranadaUI();
}
function usarGranada(){
  if(estoqueGranadas[idxGranada]>0){
    estoqueGranadas[idxGranada]-=1;
    contadorGranada.textContent=String(estoqueGranadas[idxGranada]);
  }
}

/* ===================== VIDA / DOTs / LESÃO ===================== */
const VIDA_MAX=250, BASE_ARMADURA=50, BASE_RESIST=5;
let vidaMax=VIDA_MAX, vidaAtual=VIDA_MAX, armadura=BASE_ARMADURA, resistencia=BASE_RESIST, sanidade=30;

const PLACA_VALOR=20, PLACA_ARMADURA=10, PLACA_RESIST=4, PLACA_LIMITE=2;
let placas=[];

const vidaBarra=document.getElementById('vidaBarra');
const vidaExtra=document.getElementById('vidaExtra');
const vidaCont=document.getElementById('vidaContador');
const moldura=document.getElementById('vidaFrame');
const iconSang=document.getElementById('iconSangramento');
const iconVen=document.getElementById('iconVeneno');
const iconLes=document.getElementById('iconLesao');
const placaIcon1=document.getElementById('placaIcon1');
const placaIcon2=document.getElementById('placaIcon2');

function atualizarHUD(){
  const blind=placas.reduce((a,b)=>a+b,0);
  const basePct=Math.max((vidaAtual/vidaMax)*100,0);
  vidaBarra.style.width=basePct+"%";
  const extraPct=Math.min((blind/vidaMax)*100,100-basePct);
  vidaExtra.style.width=extraPct+"%";
  vidaExtra.style.left=basePct+"%";
  vidaCont.textContent=`HP: ${Math.ceil(vidaAtual)} / ${vidaMax}`;
  document.getElementById("valorArmadura").textContent=armadura;
  document.getElementById("valorResistencia").textContent=resistencia.toFixed(1)+"%";
  document.getElementById("valorSanidade").textContent=sanidade;
  placaIcon1.classList.toggle('ativo',placas.length>=1);
  placaIcon2.classList.toggle('ativo',placas.length>=2);
}

/* Debuffs timers */
let sangramentoTimer=null, sangTicks=0;
let venenoTimer=null, venTicks=0;
let lesaoTimer=null, lesaoAtivo=false;

/* ===================== ATRIBUTOS (VALOR + MODIFICADOR) ===================== */
const attrValues={
  "FORÇA":10,
  "CONSTITUIÇÃO":10,
  "DESTREZA":10,
  "INTELIGÊNCIA":10,
  "PSICOLÓGICO":10
};

// bônus extras NOS MODS dos atributos (ex: estimulante)
const attrBonus={
  "FORÇA":0,
  "CONSTITUIÇÃO":0,
  "DESTREZA":0,
  "INTELIGÊNCIA":0,
  "PSICOLÓGICO":0
};

function calcAttrModFromValue(v){
  if(v<10) return 0;
  return Math.floor((v-10)/2)+1;
}
function getAttrTotalMod(atrib){
  const base=calcAttrModFromValue(attrValues[atrib]||0);
  const bonus=attrBonus[atrib]||0;
  return base+bonus;
}

/* ===================== PERÍCIAS: base + modificadores dinâmicos ===================== */

// bônus separados: arma e estimulante por perícia
const skillBonusWeapon={}; // ex: { "Pontaria": +3, "Reflexo": +2 }
const skillBonusStim={};   // ex: { "Armas Brancas": +5, "Percepção": +5 }
let lesaoPenalty=0;        // -2 quando lesão

// mapear base de cada skill
const periciaCols=[...document.querySelectorAll('#pericias .coluna-pericia')];
const skillsData=[]; // {span, atributo, nome, base}
periciaCols.forEach(col=>{
  const atributo=col.dataset.atrib;
  if(!atributo) return; // pula o box de ATRIBUTOS
  col.querySelectorAll('li').forEach(li=>{
    const span=li.querySelector('.mod');
    const nome=li.textContent.replace(span.textContent,'').trim();
    // Base da perícia SEM atributo = sempre 1
    const base=1;
    span.dataset.base=base;
    skillsData.push({span,atributo,nome,base});
  });
});

function renderSkills(){
  skillsData.forEach(s=>{
    const total =
      s.base +                          // 1 ponto fixo da perícia
      getAttrTotalMod(s.atributo) +     // modificador total do atributo (pontos + estimulante)
      (skillBonusWeapon[s.nome]||0) +   // bônus da arma
      (skillBonusStim[s.nome]||0) +     // bônus específico de estimulante
      lesaoPenalty;                     // penalidade global de lesão

    s.span.textContent=(total>=0?`+${total}`:String(total));
  });
  atualizarAtributosBox();
}

/* ====== GRID DE ATRIBUTOS (VISUAL) ====== */
const listaAtributos=document.getElementById('listaAtributos');
function atualizarAtributosBox(){
  if(!listaAtributos) return;
  listaAtributos.innerHTML="";
  const ordem=["FORÇA","CONSTITUIÇÃO","DESTREZA","INTELIGÊNCIA","PSICOLÓGICO"];
  ordem.forEach(nome=>{
    const val=attrValues[nome];
    const mod=calcAttrModFromValue(val);
    const li=document.createElement('li');
    li.textContent=`${nome}: ${val} = `;
    const span=document.createElement('span');
    span.className="mod";
    span.textContent=(mod>=0?`+${mod}`:String(mod));
    li.appendChild(span);
    listaAtributos.appendChild(li);
  });
}

function abrirPopupAtributos(){
  // preenche os inputs com os valores atuais
  document.getElementById('inpFor').value=attrValues["FORÇA"];
  document.getElementById('inpCon').value=attrValues["CONSTITUIÇÃO"];
  document.getElementById('inpDes').value=attrValues["DESTREZA"];
  document.getElementById('inpInt').value=attrValues["INTELIGÊNCIA"];
  document.getElementById('inpPsi').value=attrValues["PSICOLÓGICO"];
  abrir('ovAtributos');
}
document.getElementById('boxAtributos').onclick=abrirPopupAtributos;

function aplicarAtributos(){
  const campos=[
    {id:'inpFor',chave:'FORÇA'},
    {id:'inpCon',chave:'CONSTITUIÇÃO'},
    {id:'inpDes',chave:'DESTREZA'},
    {id:'inpInt',chave:'INTELIGÊNCIA'},
    {id:'inpPsi',chave:'PSICOLÓGICO'}
  ];
  campos.forEach(c=>{
    const el=document.getElementById(c.id);
    let v=parseInt(el.value,10);
    if(isNaN(v)) v=10;
    if(v<1)v=1;
    if(v>20)v=20;
    attrValues[c.chave]=v;
    el.value=v;
  });
  atualizarAtributosBox();
  renderSkills(); // recalcula tudo com os novos pontos
  fechar('ovAtributos');
}

/* ===================== SISTEMA DE ARMAS → PERÍCIAS ===================== */
const weaponSkillMap={
  "fuzil":{
    "Pontaria":3,
    "Reflexo":2,
    "Contra-ataque":1
  },
  "pistola":{
    "Pontaria":2,
    "Reflexo":1
  }
};

function limparBonusArma(){
  for(const key in skillBonusWeapon) delete skillBonusWeapon[key];
}
function aplicarBonusDaArma(){
  limparBonusArma();
  const mapa=weaponSkillMap[armaAtual];
  if(mapa){
    for(const skill in mapa){
      skillBonusWeapon[skill]=mapa[skill];
    }
  }
  renderSkills();
}

/* ===================== ESTIMULANTES ===================== */
let activeStim=null; // 'adrena' | 'iron' | 'mid' | null
let stimEndAt=0;     // timestamp fim do efeito
let globalLockUntil=0; // intervalo global 20s depois que efeito termina
const STIM_DURATION=40000; // 40s
const STIM_INTERVAL=20000; // 20s (global)

function now(){return Date.now()}
function stimLocked(){
  if(activeStim) return "Já existe estimulante ativo.";
  if(now()<globalLockUntil) return "Aguardando intervalo global.";
  return null;
}

function setStimCooldownUI(idEl, endTs){
  const el=document.getElementById(idEl);
  if(!el) return;
  function tick(){
    const rem=Math.max(0,endTs-now());
    if(rem<=0){el.textContent="";clearInterval(t);}
    else el.textContent=`Restante: ${(rem/1000).toFixed(0)}s`;
  }
  tick();
  const t=setInterval(tick,500);
}

function usarStim(kind){
  const lockMsg=stimLocked();
  if(lockMsg){alert(lockMsg);return;}

  // limpar bônus anteriores de atributo e de skill (arma fica)
  Object.keys(attrBonus).forEach(k=>attrBonus[k]=0);
  for(const k in skillBonusStim) delete skillBonusStim[k];

  if(kind==='adrena'){
    // +5 em Destreza (todas perícias de Destreza) via attrBonus
    attrBonus["DESTREZA"]+=5;
    // bônus específicos extras
    skillBonusStim["Tolerância à Dor"]=(skillBonusStim["Tolerância à Dor"]||0)+3;
    skillBonusStim["Armas Brancas"]   =(skillBonusStim["Armas Brancas"]||0)+5;
    fechar('ovAdrena');
    setStimCooldownUI('cdAdrena',now()+STIM_DURATION);
  }else if(kind==='iron'){
    attrBonus["CONSTITUIÇÃO"]+=5;
    skillBonusStim["Atletismo"]=(skillBonusStim["Atletismo"]||0)+5;
    skillBonusStim["Armas Brancas"]=(skillBonusStim["Armas Brancas"]||0)+2;
    fechar('ovIron');
    setStimCooldownUI('cdIron',now()+STIM_DURATION);
  }else if(kind==='mid'){
    attrBonus["INTELIGÊNCIA"]+=5;
    skillBonusStim["Percepção"]    =(skillBonusStim["Percepção"]||0)+5;
    skillBonusStim["Reflexo"]      =(skillBonusStim["Reflexo"]||0)+3;
    skillBonusStim["Contra-ataque"]=(skillBonusStim["Contra-ataque"]||0)+3;
    fechar('ovMid');
    setStimCooldownUI('cdMid',now()+STIM_DURATION);
  }

  activeStim=kind;
  stimEndAt=now()+STIM_DURATION;
  renderSkills();

  const endTimer=setInterval(()=>{
    if(now()>=stimEndAt){
      clearInterval(endTimer);
      Object.keys(attrBonus).forEach(k=>attrBonus[k]=0);
      for(const k in skillBonusStim) delete skillBonusStim[k];
      renderSkills();
      activeStim=null;
      globalLockUntil=now()+STIM_INTERVAL;
    }
  },250);
}

/* Grid Estimulantes – UI seletor */
(function initStimGrid(){
  const seletores=document.querySelectorAll('#item-estims .seletor');
  const imgs=[document.getElementById('stim1'),document.getElementById('stim2'),document.getElementById('stim3')];
  let ativo=0;
  function sync(){
    imgs.forEach((im,i)=>{
      im.classList.toggle('ativo',i===ativo);
      im.style.pointerEvents=(i===ativo)?'auto':'none';
    });
  }
  sync();
  seletores.forEach(btn=>btn.addEventListener('click',()=>{
    ativo=Number(btn.dataset.img)-1;
    seletores.forEach(b=>b.classList.remove('ativo'));
    btn.classList.add('ativo');
    sync();
  }));
  imgs[0].onclick=()=>abrir('ovAdrena');
  imgs[1].onclick=()=>abrir('ovIron');
  imgs[2].onclick=()=>abrir('ovMid');
})();

/* ===================== DANO / PREFIXOS (S/V/L) ===================== */
function aplicarDano(){
  const input=document.getElementById("danoInput");
  let raw=input.value.trim().toUpperCase();
  if(!raw)return;

  let tipo=null, danoBruto=0;
  if(raw.startsWith("S")){tipo="S";danoBruto=parseFloat(raw.slice(1))}
  else if(raw.startsWith("V")){tipo="V";danoBruto=parseFloat(raw.slice(1))}
  else if(raw.startsWith("L")){tipo="L";danoBruto=parseFloat(raw.slice(1))}
  else{danoBruto=parseFloat(raw)}

  if(isNaN(danoBruto)||danoBruto<=0){input.value="";return;}

  let danoPos=danoBruto*(1-resistencia/100);
  danoPos=Math.max(danoPos-armadura,0);

  let restante=danoPos;
  for(let i=placas.length-1;i>=0 && restante>0;i--){
    if(placas[i]>0){
      const hit=Math.min(placas[i],restante);
      placas[i]-=hit;
      restante-=hit;
      if(placas[i]<=0){
        placas.splice(i,1);
        armadura-=PLACA_ARMADURA;
        resistencia-=PLACA_RESIST;
      }
    }
  }
  if(restante>0)vidaAtual=Math.max(0,vidaAtual-restante);

  if(activeStim!=='iron'){
    if(tipo==="S")ativarSangramento();
    if(tipo==="V")ativarVeneno();
    if(tipo==="L")ativarLesao();
  }

  atualizarHUD();
  input.value="";
}

function ativarSangramento(){
  if(sangramentoTimer)clearInterval(sangramentoTimer);
  moldura.classList.add("efeito-vermelho");
  iconSang.classList.add("ativo");
  sangTicks=0;
  sangramentoTimer=setInterval(()=>{
    sangTicks++;
    vidaAtual=Math.max(0,vidaAtual-5);
    atualizarHUD();
    if(sangTicks>=5){
      clearInterval(sangramentoTimer);
      sangramentoTimer=null;
      moldura.classList.remove("efeito-vermelho");
      iconSang.classList.remove("ativo");
    }
  },3000);
}
function ativarVeneno(){
  if(venenoTimer)clearInterval(venenoTimer);
  moldura.classList.add("efeito-verde");
  iconVen.classList.add("ativo");
  venTicks=0;
  venenoTimer=setInterval(()=>{
    venTicks++;
    vidaAtual=Math.max(0,vidaAtual-3);
    atualizarHUD();
    if(venTicks>=6){
      clearInterval(venenoTimer);
      venenoTimer=null;
      moldura.classList.remove("efeito-verde");
      iconVen.classList.remove("ativo");
    }
  },3000);
}
function ativarLesao(){
  lesaoPenalty=-2;
  lesaoAtivo=true;
  iconLes.classList.add('ativo');
  renderSkills();
  if(lesaoTimer)clearTimeout(lesaoTimer);
  lesaoTimer=setTimeout(()=>{
    lesaoPenalty=0;
    lesaoAtivo=false;
    iconLes.classList.remove('ativo');
    renderSkills();
  },40000);
}

/* ===================== SANIDADE / ITENS (Cura/Spray/Placa) ===================== */
function alterarSanidade(v){
  sanidade=Math.min(30,Math.max(0,sanidade+v));
  atualizarHUD();
}

document.getElementById('grid-placa').onclick=()=>abrir('ovPlaca');
document.getElementById('grid-cura').onclick =()=>abrir('ovCura');
document.getElementById('grid-spray').onclick=()=>abrir('ovSpray');

function usarPlaca(){
  if(placas.length>=PLACA_LIMITE)return;
  placas.push(PLACA_VALOR);
  armadura+=PLACA_ARMADURA;
  resistencia+=PLACA_RESIST;
  atualizarHUD();
  fechar('ovPlaca');
}
function usarCura(){
  vidaAtual=Math.min(vidaAtual+30,vidaMax);
  atualizarHUD();
  let ticks=0;
  const loop=setInterval(()=>{
    vidaAtual=Math.min(vidaAtual+vidaMax*0.2,vidaMax);
    atualizarHUD();
    if(++ticks>=3)clearInterval(loop);
  },10000);

  if(sangramentoTimer){clearInterval(sangramentoTimer);sangramentoTimer=null;iconSang.classList.remove('ativo');moldura.classList.remove('efeito-vermelho')}
  if(venenoTimer){clearInterval(venenoTimer);venenoTimer=null;iconVen.classList.remove('ativo');moldura.classList.remove('efeito-verde')}
  if(lesaoTimer){clearTimeout(lesaoTimer);lesaoTimer=null;}
  lesaoPenalty=0;
  lesaoAtivo=false;
  iconLes.classList.remove('ativo');
  renderSkills();

  fechar('ovCura');
}
function usarSpray(){
  vidaAtual=Math.min(vidaAtual+20,vidaMax);
  atualizarHUD();
  let ticks=0;
  const loop=setInterval(()=>{
    vidaAtual=Math.min(vidaAtual+vidaMax*0.1,vidaMax);
    atualizarHUD();
    if(++ticks>=3)clearInterval(loop);
  },15000);
  fechar('ovSpray');
}


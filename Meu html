<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <title>HUD Combatente - RPG</title>
    <link rel="stylesheet" href="estilo.css">
</head>
<body data-player="player1"> <div class="coluna" id="arma">
  <div class="titulo">ARMA</div>
  <div class="municao-display">
    <div id="contadorFuzilNormal" class="contador">30 / 90</div>
    <div id="contadorFuzilAB" class="contador laranja inativo">25 / 75</div>
    <div id="contadorPistola" class="contador inativo">12 / 36</div>
  </div>

  <div id="nomeMunicao">MUNIÇÃO BASE</div>
  <img id="iconeTipo" class="icone-tipo icone-azul" src="https://i.imgur.com/yBeSBbD.png" onclick="trocarMunicao()">
  <button class="botao-recarregar" onclick="recarregar()">RECARREGAR</button>

  <div id="nomeGranada">GRANADA</div>
  <img id="iconeGranada" src="https://i.imgur.com/YNr8ppm.png" onclick="trocarGranada()">
  <div id="contadorGranada">3</div>
  <button id="botaoUsarGranada" onclick="usarGranada()">USAR</button>

  <div class="grid-fuzil grid-azul" id="gridFuzil">
    <div class="fuzil-inner">
      <img id="fuzilImg" src="https://i.imgur.com/nRsouNy.png">
      <img id="pistolaImg" src="https://i.imgur.com/KY3TIlI.png">
    </div>
    <button class="botao-troca" onclick="trocarArma()">
      <img id="imgTroca" src="https://i.imgur.com/LehbrQR.png">
    </button>
  </div>

  <div class="caixas-inferiores" id="botoesTiro">
    <div class="caixa" data-index="1">1</div>
    <div class="caixa" data-index="2">2</div>
    <div class="caixa" data-index="3">3</div>
    <div class="caixa" data-index="4">4</div>
    <div class="caixa" data-index="5">5</div>
  </div>

  <div class="linha-divisao"></div>
  <div class="titulo-pericia">PERÍCIAS</div>

  <div class="pericia-container" id="pericias">
    <div class="coluna-pericia" data-atrib="FORÇA">
      <div class="atributo">FORÇA</div>
      <ul>
        <li>Atletismo <span class="mod">+1</span></li>
        <li>Briga <span class="mod">+1</span></li>
        <li>Armas Brancas <span class="mod">+1</span></li>
        <li>Armas Pesadas <span class="mod">+1</span></li>
        <li>Contra-ataque <span class="mod">+1</span></li>
      </ul>
    </div>
    <div class="coluna-pericia" id="boxAtributos">
      <div class="atributo">ATRIBUTOS</div>
      <ul id="listaAtributos"></ul>
    </div>
  </div>
</div>

<div class="coluna" id="vida">
  <div class="titulo">VIDA</div>
  <div class="vida-frame" id="vidaFrame">
    <div class="placas-contador">
      <img id="placaIcon1" src="https://i.imgur.com/n8cgQJU.png">
      <img id="placaIcon2" src="https://i.imgur.com/n8cgQJU.png">
    </div>
  </div>
  <div class="vida-barra">
    <div class="vida-preenchimento" id="vidaBarra"></div>
    <div class="vida-extra" id="vidaExtra"></div>
  </div>
  <div class="vida-contador" id="vidaContador">HP: 250 / 250</div>
  <div class="status-icons">
    <img id="iconSangramento" src="https://i.imgur.com/CPcHMYH.png">
    <img id="iconVeneno"     src="https://i.imgur.com/DiIt9ie.png">
    <img id="iconLesao"      src="https://i.imgur.com/MvAV7lb.png">
  </div>
  <div class="painel-dano">
    <input type="text" id="danoInput" placeholder="Dano (ex: S80, 55)">
    <button id="btnDano">OK</button>
  </div>
</div>

<script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-database-compat.js"></script>
<script src="script.js"></script>
</body>
</html>
